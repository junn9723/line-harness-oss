# =============================================================================
# LINE Harness — Docker Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.docker.example .env
#
# Then start with:
#   docker compose up -d
# =============================================================================

# --- Required: LINE Messaging API ---
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# --- Required: API Authentication ---
# Used as Bearer token for admin API access
API_KEY=your-api-key

# --- Server ---
# Public URL for this server (used for webhook URL, image URLs, etc.)
# Set to your VPS domain: https://line.example.com
WORKER_URL=http://localhost:8787

# Port to expose (default: 8787)
PORT=8787

# --- Optional: LINE Features ---
LINE_CHANNEL_ID=
LIFF_URL=
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# --- Optional: Integrations ---
STRIPE_WEBHOOK_SECRET=
X_HARNESS_URL=

# --- Optional: Scheduling ---
# Cron pattern for step delivery, broadcasts, reminders (default: every 5 min)
CRON_SCHEDULE=*/5 * * * *

# --- Admin Dashboard ---
# URL where the API is accessible from the browser
# Used at build time for Next.js static export
NEXT_PUBLIC_API_URL=http://localhost:8787

{
  "name": "line-oss-crm",
  "version": "0.8.0",
  "private": true,
  "description": "Open-source LINE Official Account CRM/marketing automation",
  "scripts": {
    "dev:worker": "pnpm --filter worker dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "deploy:worker": "pnpm --filter worker deploy",
    "deploy:web": "pnpm --filter web build",
    "db:migrate": "wrangler d1 execute line-crm --file=packages/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute line-crm --file=packages/db/schema.sql --local",
    "deploy:setup": "node packages/create-line-harness/dist/index.js",
    "deploy:update": "node packages/create-line-harness/dist/index.js update",
    "build:node": "pnpm --filter @line-crm/shared build && pnpm --filter @line-crm/line-sdk build && pnpm --filter worker build:node",
    "start:node": "node apps/worker/dist-node/node-entry.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "wrangler": "4"
  }
}
